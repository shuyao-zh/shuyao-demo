pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }

    environment {
        MVN_ARGS = '-Dmaven.gitcommitid.skip=true'
        MAVEN_OPTS = '--add-opens=jdk.compiler/com.sun.tools.javac.processing=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.jvm=ALL-UNNAMED --add-opens=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED'
        MAVEN_VERSION = '3.9.9'
        MAVEN_DIR = ".maven/apache-maven-${MAVEN_VERSION}"
    }

    stages {
        stage('Checkout') {
            steps {
                // Avoid JGit transport issues on this agent by using CLI git over HTTPS.
                deleteDir()
                retry(3) {
                    sh '''#!/bin/bash
set -euo pipefail
BRANCH="${BRANCH_NAME:-main}"
git --version
git init
git remote add origin https://github.com/shuyao-zh/shuyao-demo.git
git fetch --depth 1 origin "$BRANCH"
git checkout -B "$BRANCH" FETCH_HEAD
'''
                }
            }
        }

        stage('Build') {
            steps {
                script {
                                        sh '''#!/bin/bash
set -euo pipefail
if command -v mvn >/dev/null 2>&1; then
    echo "System Maven found: $(mvn -v | head -n 1)"
else
    if [ ! -x "${MAVEN_DIR}/bin/mvn" ]; then
        mkdir -p .maven
        curl -fsSL "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz" -o .maven/maven.tar.gz
        tar -xzf .maven/maven.tar.gz -C .maven
    fi
fi
'''
                    def mavenSettingsArg = fileExists('settings.xml') ? '-s settings.xml' : ''
                                        sh '''#!/bin/bash
set -euo pipefail
MVN_CMD="mvn"
if ! command -v mvn >/dev/null 2>&1; then
    MVN_CMD="${MAVEN_DIR}/bin/mvn"
fi
${MVN_CMD} ''' + "${mavenSettingsArg} ${env.MVN_ARGS} -DskipTests clean package"
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    def mavenSettingsArg = fileExists('settings.xml') ? '-s settings.xml' : ''
                    sh '''#!/bin/bash
set -euo pipefail
MVN_CMD="mvn"
if ! command -v mvn >/dev/null 2>&1; then
  MVN_CMD="${MAVEN_DIR}/bin/mvn"
fi
${MVN_CMD} ''' + "${mavenSettingsArg} ${env.MVN_ARGS} test"
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                script {
                    def mavenSettingsArg = ''
                    if (fileExists('settings.xml')) {
                        // Deploy directly to Artifactory to avoid intermittent proxy-side broken pipe errors.
                        sh '''#!/bin/bash
set -euo pipefail
mkdir -p .maven
awk '
BEGIN { skip=0 }
/<proxies>/ { skip=1; next }
/<\/proxies>/ { skip=0; next }
skip==0 { print }
' settings.xml > .maven/settings-no-proxy.xml
'''
                        mavenSettingsArg = '-s .maven/settings-no-proxy.xml'
                    }
                    // Retry deploy to tolerate transient Artifactory socket resets.
                    retry(3) {
                        sh '''#!/bin/bash
set -euo pipefail
MVN_CMD="mvn"
if ! command -v mvn >/dev/null 2>&1; then
  MVN_CMD="${MAVEN_DIR}/bin/mvn"
fi
${MVN_CMD} ''' + "${mavenSettingsArg} ${env.MVN_ARGS} -DskipTests deploy"
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    junit allowEmptyResults: true, testResults: '**/surefire-reports/*.xml'
                    archiveArtifacts artifacts: 'target/*.jar', allowEmptyArchive: true
                } catch (Exception ex) {
                    echo "Skipping test report/artifact publish: ${ex.message}"
                }
            }
        }
    }
}