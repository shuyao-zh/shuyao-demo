pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        skipDefaultCheckout(true)
    }

    environment {
        MVN_ARGS = '-Dmaven.gitcommitid.skip=true'
    }

    stages {
        stage('Checkout') {
            steps {
                // Use SSH over 443 with explicit credentials to avoid HTTPS truststore issues and blocked port 22.
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${env.BRANCH_NAME ?: 'main'}"]],
                    doGenerateSubmoduleConfigurations: false,
                    extensions: [[
                        $class: 'CloneOption',
                        shallow: true,
                        depth: 1,
                        noTags: true,
                        timeout: 30
                    ]],
                    userRemoteConfigs: [[
                        credentialsId: 'DevSecOps_SCM_SSH_CLONE_PRIVATE_KEY',
                        url: 'ssh://git@ssh.github.com:443/shuyao-zh/shuyao-demo.git'
                    ]]
                ])
            }
        }

        stage('Build') {
            steps {
                script {
                    def mavenSettingsArg = fileExists('settings.xml') ? '-s settings.xml' : ''
                    sh "mvn ${mavenSettingsArg} ${env.MVN_ARGS} -DskipTests clean package"
                }
            }
        }

        stage('Test') {
            steps {
                script {
                    def mavenSettingsArg = fileExists('settings.xml') ? '-s settings.xml' : ''
                    sh "mvn ${mavenSettingsArg} ${env.MVN_ARGS} test"
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    junit allowEmptyResults: true, testResults: '**/surefire-reports/*.xml'
                    archiveArtifacts artifacts: 'target/*.jar', allowEmptyArchive: true
                } catch (Exception ex) {
                    echo "Skipping test report/artifact publish: ${ex.message}"
                }
            }
        }
    }
}